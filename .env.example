# Server Configuration
PORT=3000
HOST=0.0.0.0

# Database Configuration (PostgreSQL Docker Defaults)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=majestic_family
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/majestic_family

# Redis Configuration (Docker Defaults)
REDIS_URL=redis://localhost:6379

# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# Access Control
BOT_OWNER_ID=your_discord_user_id_here

# OAuth Configuration
VITE_API_URL=http://localhost:3000
HOST_URL=http://localhost:5173

# Admin/Public host URLs (used for redirects + CORS)
PUBLIC_HOST_URL=http://localhost:5173
ADMIN_HOST_URL=http://admin.localhost:5173

# Session cookie domain (dev: .localhost, prod: .example.com)
COOKIE_DOMAIN=.localhost

# IPC (backend <-> bot) base URLs
# backend -> bot (bot IPC server)
IPC_BOT_BASE_URL=http://localhost:3001
# bot -> backend (REST endpoints for IPC)
IPC_BACKEND_BASE_URL=http://localhost:3000
# bot IPC listen host (Docker: 0.0.0.0)
IPC_BOT_LISTEN_HOST=0.0.0.0
